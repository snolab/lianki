# ── Lianki local development env ────────────────────────────────────────────
# Copy to `.env.local` (gitignored) for a fully working local app you can sign
# in to and QA end-to-end with NO external services (no Cloudflare/Turnstile,
# no SMTP, no OAuth apps, no remote DB).
#
#   cp .env.local.example .env.local
#   bun run dev:db     # terminal 1 — local MongoDB replica set on :27018
#   bun run dev        # terminal 2 — Next.js on :3000

# Database backend: "mongodb" (default) or "d1".
DB_BACKEND=mongodb

# Local MongoDB started by `bun run dev:db`. It is a single-node REPLICA SET
# (?replicaSet=rs0) because better-auth's mongo adapter uses transactions.
MONGODB_URI=mongodb://127.0.0.1:27018/lianki-dev?replicaSet=rs0

# better-auth. Any random string works in dev:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-random-dev-secret
BETTER_AUTH_BASE_URL=http://localhost:3000

# Dev-only email+password sign-in/up, so you can log in without OAuth or SMTP.
# The sign-in UI already supports this; auth.ts only honors the flag when
# NODE_ENV !== production, so it can never be enabled on the deployed app.
DEV_EMAIL_PASSWORD_AUTH=1

# Turnstile (CAPTCHA): only the magic-link button uses it. Password sign-in
# (the dev path above) does not, so you can leave these unset. The public test
# sitekey below always passes if you do want the widget to render.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Optional: only needed for the corresponding features ─────────────────────
# OPENAI_API_KEY=          # AI vocab, roadmap generate, translation, TTS
# YOUTUBE_API_KEY=         # /learn YouTube playlist import
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=      # GitHub OAuth sign-in
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=      # Google OAuth sign-in
# EMAIL_SERVER=            # nodemailer SMTP URL — enables real magic-link email
# EMAIL_FROM=
